# Nefasto Project Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# ═══════════════════════════════════════════════════════════════
# GRAPHIFY / KNOWLEDGE GRAPH GENERATION
# ═══════════════════════════════════════════════════════════════

# OpenRouter API Key (get free at https://openrouter.ai)
# Free tier: 5M tokens/month with various models
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# Model to use (free tier options from OpenRouter):
# - mistralai/mistral-7b-instruct:free        (Fast, good quality)
# - meta-llama/llama-2-7b-chat:free           (Meta's Llama 2)
# - gryphe/mythomist-7b:free                  (Specialized)
# - openchat/openchat-7b:free                 (Fast inference)
GRAPHIFY_MODEL=mistralai/mistral-7b-instruct:free

# Input source (file path, URL, or directory)
GRAPHIFY_INPUT=README.md

# Output directory for knowledge graph
GRAPHIFY_OUTPUT=graphify-out

# Graph format (json, yaml, etc)
GRAPHIFY_FORMAT=json

# Input type (auto, code, markdown, text)
GRAPHIFY_INPUT_TYPE=auto

# ═══════════════════════════════════════════════════════════════
# GENERATION PARAMETERS
# ═══════════════════════════════════════════════════════════════

# Temperature for generation (0.0-1.0)
# Lower = more deterministic, Higher = more creative
GRAPHIFY_TEMPERATURE=0.7

# Max tokens for response (increase for longer outputs)
GRAPHIFY_MAX_TOKENS=2000

# Top-p sampling (nucleus sampling)
GRAPHIFY_TOP_P=0.95

# ═══════════════════════════════════════════════════════════════
# LOGGING & DEBUG
# ═══════════════════════════════════════════════════════════════

# Verbose logging (true/false)
GRAPHIFY_VERBOSE=false

# Debug mode (true/false)
GRAPHIFY_DEBUG=false

# ═══════════════════════════════════════════════════════════════
# PROLOG NARRATIVE GENERATION
# ═══════════════════════════════════════════════════════════════

# Language for narrative generation (en/es)
NARRATIVE_LANG=en

# Random seed for reproducibility (optional)
NARRATIVE_SEED=42

# Narrative type (simple_story, dialogue, description)
NARRATIVE_TYPE=simple_story

# ═══════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════

# OpenRouter Free Tier:
#   - Sign up at: https://openrouter.ai
#   - Get API key from: https://openrouter.ai/keys
#   - Free: 5M tokens/month
#   - No credit card required initially
#   - Multiple free models available
#
# Free Models Available:
#   - mistralai/mistral-7b-instruct:free  ← Recommended for graphify
#   - meta-llama/llama-2-7b-chat:free
#   - gryphe/mythomist-7b:free
#   - openchat/openchat-7b:free
#
# Usage Examples:
#   ./scripts/run-graphify.sh README.md
#   ./scripts/run-graphify.sh src/
#   GRAPHIFY_MODEL=meta-llama/llama-2-7b-chat:free ./scripts/run-graphify.sh
