# Graphify Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# Graphify API Key (for Claude AI knowledge graph generation)
GRAPHIFY_API_KEY=your-api-key-here

# Input source (file path, URL, or directory)
GRAPHIFY_INPUT=README.md

# Output directory for knowledge graph
GRAPHIFY_OUTPUT=graphify-out

# Graph format (json, yaml, etc)
GRAPHIFY_FORMAT=json

# Optional: Anthropic API key (if using Claude API directly)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: Model to use
GRAPHIFY_MODEL=claude-opus-4-8

# Optional: Temperature for generation
GRAPHIFY_TEMPERATURE=0.7

# Optional: Max tokens for response
GRAPHIFY_MAX_TOKENS=2000

# Optional: Input type (auto, code, markdown, text)
GRAPHIFY_INPUT_TYPE=auto

# Optional: Verbose logging
GRAPHIFY_VERBOSE=false

# Optional: Debug mode
GRAPHIFY_DEBUG=false
